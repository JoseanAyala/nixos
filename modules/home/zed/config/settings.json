// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "sidebar_side": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "icon_theme": "Zed (Default)",
  "session": {
    "trust_all_worktrees": true
  },
  "vim_mode": true,
  // Match LazyVim's vim options
  "vim": {
    "use_system_clipboard": "always", // clipboard=unnamedplus
    "use_smartcase_find": true,
    "highlight_on_yank_duration": 150
  },
  "relative_line_numbers": "enabled", // number + relativenumber
  "vertical_scroll_margin": 4, // scrolloff=4
  "use_smartcase_search": true, // ignorecase + smartcase
  "seed_search_query_from_cursor": "selection",
  "cursor_blink": false,
  "scroll_beyond_last_line": "one_page",
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "ui_font_size": 20,
  "buffer_font_size": 18,
  "theme": {
    "mode": "dark",
    "light": "Noctalia Light",
    "dark": "Noctalia Dark",
  },
}
